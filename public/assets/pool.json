  "expressions": {
    "list": [
      {
        "type": "text",
        "id": "580",
        "text": "https://www.desmos.com/calculator/saputpokee"
      },
      {
        "type": "text",
        "id": "498",
        "text": "This is my submission to the 2024 art expo! It's a fully playable (but a little simplified to improve performance) game of 8 ball complete with elastic collision."
      },
      {
        "type": "text",
        "id": "501",
        "text": "I do a lot of programming in my free time, and I'm working on my math skills to prepare for high school. I saw that the art expo was coming up and this was the perfect excuse to create a detailed physics simulation and do two things that I love doing - math and programming. So, I decided to make this pool table! It's a very fun strategy based game that requires a mix of mental and physical capability, which I find a very interesting dynamic."
      },
      {
        "type": "text",
        "id": "503",
        "text": "To play, start the ticker, then move the cuestick by dragging the tip. Once you have aimed your shot, click the \"Launch\" button. After all the balls settle, you can play another round."
      },
      {
        "type": "text",
        "id": "505",
        "text": "You can find full BCA Pool League rules here: https://www.playcsipool.com/bcapl-rules.html"
      },
      {
        "type": "text",
        "id": "506",
        "text": "The pool table is also made to match the regulation as close as I could."
      },
      {
        "type": "text",
        "id": "507",
        "text": "~~~~~~~~~~~~~~~~~Have fun :D~~~~~~~~~~~~~~~~~"
      },
      {
        "type": "text",
        "id": "521",
        "text": "(If it's running slow, try turning off shadows)"
      },
      {
        "type": "expression",
        "id": "461",
        "color": "#c74440",
        "latex": "s_{hadows}=1",
        "slider": {
          "hardMin": true,
          "hardMax": true,
          "min": "0",
          "max": "1",
          "step": "1"
        }
      },
      {
        "type": "text",
        "id": "524",
        "text": "⚠️ math ahead 😱"
      },
      {
        "type": "text",
        "id": "574",
        "text": "launch launches the cue ball based on the position of the cuestick."
      },
      {
        "type": "expression",
        "id": "382",
        "color": "#2d70b3",
        "latex": "l_{aunch}=\\left\\{c_{anlaunch}<l_{aunchspeed}:c_{uevel}\\to c_{uevel}+\\frac{c_{ue}-s_{tick}}{\\left|c_{ue}-s_{tick}\\right|}\\sqrt{\\left|c_{ue}-s_{tick}\\right|}p_{ower}\\right\\}"
      },
      {
        "type": "text",
        "id": "575",
        "text": "Reset all of the positions, velocities, etc."
      },
      {
        "type": "expression",
        "id": "81",
        "color": "#6042a6",
        "latex": "r_{eset}=c_{ue}\\to h_{ead},b_{allpos}\\to p_{ositions},v_{els}\\to z_{erovels},c_{uevel}\\to\\left(0,0\\right),v_{isible}\\to\\left[1\\operatorname{for}i=\\left[1...16\\right]\\right]"
      },
      {
        "type": "text",
        "id": "576",
        "text": "A tick function that updates the positions and velocities of the balls."
      },
      {
        "type": "expression",
        "id": "121",
        "color": "#c74440",
        "latex": "t_{ick}=\\left\\{t_{icktype}=0:u_{pdatepos},u_{pdatevel}\\right\\},\\left\\{t_{icktype}=0:t_{icktype}\\to1,t_{icktype}\\to0\\right\\},\\left\\{t_{icktype}=1:u_{pdatevisible}\\right\\}"
      },
