        "latex": "s_{tickpoly}=\\left[o_{ffset}\\left(s_{tick},a_{ngle}\\left(s_{tick},c_{ue}\\right)+\\frac{\\pi}{2},\\frac{s_{tickwidthend}}{2}\\right),o_{ffset}\\left(s_{tick},a_{ngle}\\left(s_{tick},c_{ue}\\right)-\\frac{\\pi}{2},\\frac{s_{tickwidthend}}{2}\\right),o_{ffset}\\left(o_{ffset}\\left(s_{tick},a_{ngle}\\left(s_{tick},c_{ue}\\right)+\\pi,s_{ticklen}\\right),a_{ngle}\\left(s_{tick},c_{ue}\\right)-\\frac{\\pi}{2},\\frac{s_{tickwidthstart}}{2}\\right),o_{ffset}\\left(o_{ffset}\\left(s_{tick},a_{ngle}\\left(s_{tick},c_{ue}\\right)+\\pi,s_{ticklen}\\right),a_{ngle}\\left(s_{tick},c_{ue}\\right)+\\frac{\\pi}{2},\\frac{s_{tickwidthstart}}{2}\\right)\\right]",
        "hidden": true
