        "color": "#c74440",
        "latex": "s_{tickendpoly}=\\left[o_{ffset}\\left(s_{tick},a_{ngle}\\left(s_{tick},c_{ue}\\right)+\\frac{\\pi}{2},\\frac{s_{tickwidthend}}{2}\\right),o_{ffset}\\left(s_{tick},a_{ngle}\\left(s_{tick},c_{ue}\\right)-\\frac{\\pi}{2},\\frac{s_{tickwidthend}}{2}\\right),o_{ffset}\\left(o_{ffset}\\left(s_{tick},a_{ngle}\\left(s_{tick},c_{ue}\\right)+\\pi,s_{tickendlen}\\right),a_{ngle}\\left(s_{tick},c_{ue}\\right)-\\frac{\\pi}{2},\\frac{s_{tickwidthend}}{2}\\right),o_{ffset}\\left(o_{ffset}\\left(s_{tick},a_{ngle}\\left(s_{tick},c_{ue}\\right)+\\pi,s_{tickendlen}\\right),a_{ngle}\\left(s_{tick},c_{ue}\\right)+\\frac{\\pi}{2},\\frac{s_{tickwidthend}}{2}\\right)\\right]",
        "hidden": true
